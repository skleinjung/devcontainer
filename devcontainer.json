{
  "containerEnv": {
    "NODE_OPTIONS": "--experimental-transform-types --no-warnings=ExperimentalWarning",
    "PW_CHROMIUM_SANDBOX": "0",
    "VSCODE_AGENT_FOLDER": "/vscode",
    // Agent credentials (AWS + GitHub) come from the read-only /creds shelf vended by the
    // admin sidecar — this container can neither mint nor widen them (see
    // .devcontainer/README.md). NOTE: setting AWS_PROFILE to an SSO profile overrides the
    // shelf [default] — don't set it (shell / .claude/settings.local.json).
    "AWS_SHARED_CREDENTIALS_FILE": "/creds/aws/credentials",
    // This workspace's primary GitHub org — the default vended token for `gh`/git when no repo
    // context pins an org (gh against a specific -R/cwd-remote, and git per its path, still route
    // per-org). Must match a vended org (admin-sidecar/github-installations.json).
    "GH_DEFAULT_ORG": "skleinjung",
    // Default region for AWS CLI/SDK calls — the vended credentials file carries credentials
    // only, no region. A region is not account-revealing.
    "AWS_REGION": "us-east-1",
    // Make Claude Code fetch the plugin marketplace over HTTPS instead of git@github.com (ssh).
    // The forwarded FIDO/yubikey agent is the only github ssh credential, so an ssh fetch prompts a
    // hardware touch on every startup; HTTPS rides the App-token auth above instead. (The startup
    // ssh connectivity probe is handled separately by the ~/.claude/bin/ssh shim.)
    "CLAUDE_CODE_PLUGIN_PREFER_HTTPS": "1"
    
  },
  "customizations": {
    "vscode": {
      "settings": {
        "dev.containers.dockerCredentialHelper": false,
        // Don't inject GIT_ASKPASS: it forwards credential prompts to VS Code, which can hand a
        // process the human's VS Code GitHub login (a broad personal OAuth token) — far more than
        // the scoped shelf tokens agents are meant to have. git/gh are unaffected (they use the
        // git-credential-shelf helper). A profile.d scrub (post-create) covers the residual env.
        "git.useIntegratedAskPass": false,
        // Don't inject VS Code's host-credential-proxy helper into the container's gitconfig —
        // a separate forwarding path that would bridge the HOST's stored git credentials into an
        // agent's reach. (Complements useIntegratedAskPass above, which covers the askpass/OAuth
        // path; neither alone is sufficient — see vscode-remote-release#4426.) Agents get only
        // the scoped /creds shelf token via git-credential-shelf.
        "remote.containers.gitCredentialHelperConfigLocation": "none",
        // Don't copy the host's ~/.gitconfig (and .git-credentials) into the container — that
        // default would import the host's credential.helper, user.signingkey, and any plaintext
        // .git-credentials token. Agents use the dotfiles gitconfig + the shelf helper only.
        "remote.containers.copyGitConfig": false,
        // Don't register VS Code as the terminal Git editor — its git-editor IPC socket is reaped
        // (see entrypoint), and git uses nano (core.editor, baked in the Dockerfile) instead.
        "git.terminalGitEditor": false,
        "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
      }
    }
  },
  "dockerComposeFile": ["docker-compose.yml"],
  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    // Docker is intentionally absent: the host socket (docker-outside-of-docker) gives agents
    // root-equivalent reach onto the host, and docker-in-docker requires a privileged container.
    // Replacement is an external agent-domain daemon — https://github.com/twin-digital/opus/issues/164.
    // Only uncomment one of the following if you need docker before that lands:
    // "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
    //   "moby": false
    // },
    // "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {}
  },
  "forwardPorts": [3001, 7470],
  "portsAttributes": {},
  "init": true,
  "initializeCommand": ".devcontainer/scripts/host/initialize.sh",
  "name": "Workspace",
  // false so VS Code keeps the compose entrypoint/command (the socket reaper) instead of replacing
  // it with its own keep-alive. The entrypoint runs the reaper and `sleep infinity` itself.
  "overrideCommand": false,
  "postAttachCommand": "/usr/local/bin/post-attach",
  "postCreateCommand": "/usr/local/bin/post-create",
  "remoteEnv": {
    // Blank VS Code's host-reaching channels so agents are confined to the scoped /creds shelf.
    // remoteEnv applies to EVERY process VS Code spawns (terminals AND the agent's own bash
    // subprocesses) — the shell scrub alone misses non-interactive `bash -c`, which is how agents
    // run commands. Emptied, not removed: an empty value is as good as unset for these.
    //   - GIT_ASKPASS / VSCODE_GIT_* : VS Code's credential askpass → your VS Code GitHub OAuth
    //     token (broad). The git extension stays enabled (Source Control UI works via the shelf
    //     helper); we just don't hand agents the askpass pointer.
    //   - VSCODE_IPC_HOOK_CLI : the `code` CLI channel — running `code`/--openExternal acts on the
    //     host side. BROWSER : openExternal's browser/command launcher. GPG_AGENT_INFO : host GPG.
    // SSH_AUTH_SOCK is intentionally LEFT in place — it's the forwarded FIDO/YubiKey agent
    // (hardware-touch-gated) and is used for SSH-remote git in the terminal/UI.
    "GIT_ASKPASS": "",
    "VSCODE_GIT_IPC_HANDLE": "",
    "VSCODE_GIT_ASKPASS_MAIN": "",
    "VSCODE_GIT_ASKPASS_NODE": "",
    "VSCODE_GIT_ASKPASS_EXTRA_ARGS": "",
    "VSCODE_IPC_HOOK_CLI": "",
    "BROWSER": "",
    "GPG_AGENT_INFO": ""
  },
  "remoteUser": "${localEnv:USER}",
  "service": "workspace",
  "workspaceFolder": "/workspace"
}
