{
  "containerEnv": {
    "NODE_OPTIONS": "--experimental-transform-types --no-warnings=ExperimentalWarning",
    "PW_CHROMIUM_SANDBOX": "0",
    "VSCODE_AGENT_FOLDER": "/vscode",
    // Agent credentials (AWS + GitHub) come from the read-only /creds shelf vended by the
    // admin sidecar — this container can neither mint nor widen them (see
    // .devcontainer/README.md). NOTE: setting AWS_PROFILE to an SSO profile overrides the
    // shelf [default] — don't set it (shell / .claude/settings.local.json).
    "AWS_SHARED_CREDENTIALS_FILE": "/creds/aws/credentials",
    // This workspace's primary GitHub org — the default vended token for `gh`/git when no repo
    // context pins an org (gh against a specific -R/cwd-remote, and git per its path, still route
    // per-org). Must match a vended org (admin-sidecar/github-installations.json).
    "GH_DEFAULT_ORG": "skleinjung",
    // Default region for AWS CLI/SDK calls — the vended credentials file carries credentials
    // only, no region. A region is not account-revealing.
    "AWS_REGION": "us-east-1",
    // Make Claude Code fetch the plugin marketplace over HTTPS instead of git@github.com (ssh).
    // The forwarded FIDO/yubikey agent is the only github ssh credential, so an ssh fetch prompts a
    // hardware touch on every startup; HTTPS rides the App-token auth above instead. (The startup
    // ssh connectivity probe is handled separately by the ~/.claude/bin/ssh shim.)
    "CLAUDE_CODE_PLUGIN_PREFER_HTTPS": "1"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "dev.containers.dockerCredentialHelper": false,
        "extensions": ["dbaeumer.vscode-eslint", "esbenp.prettier-vscode"]
      }
    }
  },
  "dockerComposeFile": ["docker-compose.yml"],
  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    // Docker is intentionally absent: the host socket (docker-outside-of-docker) gives agents
    // root-equivalent reach onto the host, and docker-in-docker requires a privileged container.
    // Replacement is an external agent-domain daemon — https://github.com/twin-digital/opus/issues/164.
    // Only uncomment one of the following if you need docker before that lands:
    // "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
    //   "moby": false
    // },
    // "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/python:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {}
  },
  "forwardPorts": [3001, 7470],
  "portsAttributes": {},
  "init": true,
  "initializeCommand": ".devcontainer/scripts/host/initialize.sh",
  "name": "Workspace",
  "overrideCommand": true,
  "postAttachCommand": "/usr/local/bin/post-attach",
  "postCreateCommand": "/usr/local/bin/post-create",
  "remoteEnv": {
    // to enable, need to rename `10-start-filter-agent.sh.DISABLED` as well
    // "SSH_AUTH_SOCK": "/tmp/ssh-filter/agent.sock"
  },
  "remoteUser": "${localEnv:USER}",
  "service": "workspace",
  "workspaceFolder": "/workspace"
}
