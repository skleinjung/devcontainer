#!/usr/bin/env bash
# Workspace container entrypoint (wired via docker-compose `entrypoint`). Continuously reaps VS
# Code's CLI and git-extension IPC sockets so untrusted code in this container cannot reach them,
# then runs the container's command.
#
# Reaps:
#   /tmp/vscode-ipc-*.sock  — the `code` CLI channel (incl. `code --install-extension`, a bootstrap
#                             into the extension host / the #5 RCE chain)
#   /tmp/vscode-git-*.sock  — the git extension's askpass (OAuth token) + git-editor IPC
# KEEPS (must not delete):
#   vscode-remote-containers-*.sock — the IDE<->container channel; deleting it breaks VS Code
#   vscode-ssh-auth-*.sock          — the forwarded FIDO agent we intentionally keep (touch-gated)
#
# Env-blanking (remoteEnv + the shell scrub) only hides the pointers; this removes the sockets
# themselves. VS Code recreates them at multiple points (some 60s+ after attach), so the reaper
# runs forever. It runs as a child of the container's main process (NOT a VS Code lifecycle hook),
# so VS Code's cgroup cleanup can't kill it. This is defense-in-depth, not a wall — there is a
# brief window between recreation and the next sweep. See SECURITY.md.
set -euo pipefail

(
  while true; do
    find /tmp -maxdepth 1 -type s \
      \( -name 'vscode-ipc-*.sock' -o -name 'vscode-git-*.sock' \) -delete 2>/dev/null || true
    sleep 2
  done
) &

if [ "$#" -gt 0 ]; then
  exec "$@"
else
  exec sleep infinity
fi
