#!/usr/bin/env bash
#
# gh-shelf-resolve [org] — print the shelf token-file path for an (optional) org, or exit 1 if it
# can't be resolved unambiguously. The single place the org→token-file mapping is decided, so the
# gh wrapper, the git credential helper, and gh-token-get/seed all agree.
#
# Resolution order:
#   1. explicit org arg        -> /creds/github/<org>
#   2. $GH_TOKEN_SHELF         -> that exact path (full override)
#   3. $GH_DEFAULT_ORG         -> /creds/github/<org>   (the workspace's primary org)
#   4. exactly one token file  -> that file             (unambiguous single-org setup)
# Prints nothing and exits 1 when none apply (no org, no default, 0 or >1 tokens).
#
set -euo pipefail

org="${1:-}"
base="${GH_SHELF_DIR:-/creds/github}"

if [ -n "$org" ]; then printf '%s/%s' "$base" "$org"; exit 0; fi
if [ -n "${GH_TOKEN_SHELF:-}" ]; then printf '%s' "$GH_TOKEN_SHELF"; exit 0; fi
if [ -n "${GH_DEFAULT_ORG:-}" ]; then printf '%s/%s' "$base" "$GH_DEFAULT_ORG"; exit 0; fi

shopt -s nullglob
files=("$base"/*)
shopt -u nullglob
[ "${#files[@]}" -eq 1 ] && { printf '%s' "${files[0]}"; exit 0; }
exit 1
