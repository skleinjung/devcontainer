#!/usr/bin/env bash
#
# git-credential-shelf — git credential helper that serves the admin-sidecar-vended GitHub token
# matching the org being accessed. Wired (with credential.useHttpPath=true) so git passes the
# repo path; we route on its first segment (the org) to /creds/github/<org> via gh-token-get.
#
# git invokes it as `git-credential-shelf get` with the request on stdin:
#     protocol=https
#     host=github.com
#     path=twin-digital/opus.git
# We only answer for github.com; anything else (or an unresolvable/expired token) produces no
# output, so git falls through to the next helper / fails as it normally would (fail-open).
# store/erase are no-ops — there is nothing to persist; tokens live only on the shelf.
#
set -euo pipefail

[ "${1:-}" = "get" ] || exit 0

host="" path=""
while IFS='=' read -r key value; do
  case "$key" in
    host) host="$value" ;;
    path) path="$value" ;;
    "") break ;; # blank line terminates the request
  esac
done

[ "$host" = "github.com" ] || exit 0

# org = first path segment (path is "owner/repo.git" when useHttpPath is on; empty otherwise, in
# which case gh-token-get falls back to GH_DEFAULT_ORG / a single vended token).
org="${path%%/*}"

token="$(gh-token-get "$org" 2>/dev/null || true)"
[ -n "$token" ] || exit 0

printf 'username=x-access-token\n'
printf 'password=%s\n' "$token"
