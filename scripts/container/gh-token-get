#!/usr/bin/env bash
#
# gh-token-get — print a currently-valid GitHub token for gh/git.
#
# Called by the `gh` wrapper (and thus by git, via `gh auth git-credential`) whenever gh/git
# needs a token. The ONLY source is the pre-scoped token the admin sidecar vends to the /creds
# shelf ("<exp_epoch> <token>"); this container has no minting capability (no kms:Sign — see
# /workspace/.devcontainer/README.md). $GH_TOKEN_SHELF selects the token file, for consumers
# that need a token vended under a different name. On any failure it prints nothing -> the
# caller is simply unauthenticated (fail-open), with a stderr breadcrumb explaining why.
#
set -euo pipefail

SHELF_TOKEN="${GH_TOKEN_SHELF:-/creds/github/opus}"
SKEW="${GH_TOKEN_SKEW:-300}" # treat tokens with < 5 min remaining as expired
now=$(date +%s)

line="$(cat "$SHELF_TOKEN" 2>/dev/null || true)"
if [ -n "$line" ]; then
  exp="${line%% *}"
  tok="${line#* }"
  if [ -n "$tok" ] && [ "$exp" -gt "$((now + SKEW))" ] 2>/dev/null; then
    printf '%s' "$tok"
    exit 0
  fi
fi

# Fail-open (nothing on stdout) but self-diagnosing on stderr, so a failed gh/git call carries
# its own fix instead of surfacing as a cryptic 401/404.
{
  echo "gh-token-get: no valid GitHub token available."
  echo "  shelf:       $SHELF_TOKEN ($([ -e "$SHELF_TOKEN" ] && echo stale || echo missing))"
  echo "  vend status: $(cat /creds/status/github 2>/dev/null || echo 'absent (sidecar not vending?)')"
  echo "  admin fix:   docker exec -it admin-sidecar aws-refresh-sso <profile>  (from a HOST terminal)"
  echo "  details:     /workspace/.devcontainer/README.md"
} >&2
exit 0
