#!/usr/bin/env bash
#
# gh-token-get [org] — print a currently-valid GitHub token for gh/git.
#
# Called by the `gh` wrapper and by git (via the git-credential-shelf helper) whenever gh/git
# needs a token. The ONLY source is the pre-scoped token the admin sidecar vends to the /creds
# shelf ("<exp_epoch> <token>"); this container has no minting capability (no kms:Sign — see
# /workspace/.devcontainer/README.md). The org argument (or $GH_TOKEN_SHELF / $GH_DEFAULT_ORG)
# selects which vended token, via gh-shelf-resolve. On any failure it prints nothing -> the
# caller is simply unauthenticated (fail-open), with a stderr breadcrumb explaining why.
#
set -euo pipefail

org="${1:-}"
SKEW="${GH_TOKEN_SKEW:-300}" # treat tokens with < 5 min remaining as expired
now=$(date +%s)

shelf="$(gh-shelf-resolve "$org" 2>/dev/null || true)"

if [ -n "$shelf" ]; then
  line="$(cat "$shelf" 2>/dev/null || true)"
  if [ -n "$line" ]; then
    exp="${line%% *}"
    tok="${line#* }"
    if [ -n "$tok" ] && [ "$exp" -gt "$((now + SKEW))" ] 2>/dev/null; then
      printf '%s' "$tok"
      exit 0
    fi
  fi
fi

# Fail-open (nothing on stdout) but self-diagnosing on stderr, so a failed gh/git call carries
# its own fix instead of surfacing as a cryptic 401/404.
{
  echo "gh-token-get: no valid GitHub token available${org:+ for org '$org'}."
  if [ -n "$shelf" ]; then
    echo "  shelf:       $shelf ($([ -e "$shelf" ] && echo stale || echo missing))"
    echo "  vend status: $(cat "/creds/status/github-$(basename "$shelf")" 2>/dev/null || echo 'absent (sidecar not vending this org?)')"
  else
    echo "  could not resolve a token file: pass an org, set GH_DEFAULT_ORG, or vend exactly one org."
    echo "  vended orgs: $(ls /creds/github 2>/dev/null | tr '\n' ' ' || echo none)"
  fi
  echo "  admin fix:   docker exec -it admin-sidecar aws-refresh-sso <profile>  (from a HOST terminal)"
  echo "  details:     /workspace/.devcontainer/README.md"
} >&2
exit 0
