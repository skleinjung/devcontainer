#!/usr/bin/env bash
#
# gh-token-seed — Claude SessionStart check: surface credential problems at session start
# instead of mid-task. Exits 0 when a usable GitHub token is on the shelf for GH_DEFAULT_ORG,
# else non-zero with a one-line reason. Resolves via base's `devcred`; nothing here mints or
# refreshes — the credential sidecar vends.
#
set -euo pipefail

org="${GH_DEFAULT_ORG:-}"
[ -n "$org" ] || { echo "GH_DEFAULT_ORG is not set" >&2; exit 1; }

if [ -n "$(devcred get "github/$org" 2>/dev/null || true)" ]; then
  exit 0
fi

echo "no valid GitHub token for org '$org' — is a credential sidecar attached and logged in?" >&2
echo "  check: cat /creds/status/*   (and 'aws sso login' in the credentials-aws sidecar)" >&2
exit 1
