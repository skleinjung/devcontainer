#!/usr/bin/env bash
#
# vend-aws-creds — publish short-lived AWS credentials for the agent role(s) onto the /creds shelf.
#
# Runs as a loop under vend-daemon (the sidecar's main process). For each profile in $VEND_AWS_PROFILES (space-
# separated; each must exist in the admin user's ~/.aws/config), resolves credentials from the
# admin user's SSO session (`aws configure export-credentials`) and atomically writes a single
# ini credentials file: the FIRST profile doubles as [default], and every profile also gets a
# named section, so agents select roles with AWS_PROFILE=<name>. The workspace container
# consumes it via AWS_SHARED_CREDENTIALS_FILE=/creds/aws/credentials (mounted read-only there).
# The agent never holds more than the vended roles — escalation means a human vends something
# broader from this container. Design context: https://github.com/twin-digital/opus/issues/164
#
# With no (or an expired) SSO session it just logs and keeps waiting: run
#   aws sso login --profile <profile>
# in this container to (re)start the flow. `vend-aws-creds --once` vends a single time and exits
# nonzero if nothing could be vended (useful interactively).
set -euo pipefail

PROFILES="${VEND_AWS_PROFILES:-agent}"
SHELF="${VEND_SHELF_DIR:-/creds}/aws"
REFRESH_BEFORE="${VEND_REFRESH_BEFORE:-900}" # re-vend when less than 15 min remain
CHECK_INTERVAL="${VEND_CHECK_INTERVAL:-60}"

log() { printf '%s vend-aws-creds: %s\n' "$(date -Is)" "$*"; }

# Health stamp for consumers (shell prompts, gh-token-get breadcrumbs, future healthchecks):
# one line, "ok ..." or "stalled ...", rewritten every cycle so mtime doubles as a heartbeat.
STATUS_FILE="${VEND_SHELF_DIR:-/creds}/status/aws"
stalled_since=""
status_write() {
  local tmp
  mkdir -p "${STATUS_FILE%/*}"
  tmp=$(mktemp "${STATUS_FILE%/*}/.aws.XXXXXX")
  printf '%s\n' "$1" >"$tmp"
  mv "$tmp" "$STATUS_FILE"
}
status_ok() {
  stalled_since=""
  status_write "ok expires=$(cat "$SHELF/expiration" 2>/dev/null || echo unknown)"
}
status_stalled() {
  [ -n "$stalled_since" ] || stalled_since=$(date -Is)
  status_write "stalled since=$stalled_since fix=\"docker exec -it admin-sidecar aws-refresh-sso <profile>\" logs=\"docker logs admin-sidecar\""
}

# Re-vend only when the published credentials are missing or near expiry (the stamp holds the
# EARLIEST expiry across profiles), so the steady state is a cheap local file check. The CLI
# caches SSO role credentials, so re-exporting all profiles together costs little.
needs_vend() {
  local exp exp_epoch
  exp=$(cat "$SHELF/expiration" 2>/dev/null) || return 0
  exp_epoch=$(date -d "$exp" +%s 2>/dev/null) || return 0
  [ $((exp_epoch - $(date +%s))) -lt "$REFRESH_BEFORE" ]
}

write_section() {
  local name="$1" akid="$2" secret="$3" token="$4"
  printf '[%s]\naws_access_key_id = %s\naws_secret_access_key = %s\n' "$name" "$akid" "$secret"
  [ -z "$token" ] || printf 'aws_session_token = %s\n' "$token"
  printf '\n'
}

vend() {
  local json err akid secret token exp exp_epoch tmp
  local first=1 vended=0 failed=0 min_exp="" min_exp_epoch=""

  umask 077
  mkdir -p "$SHELF"
  tmp=$(mktemp "$SHELF/.credentials.XXXXXX")
  err=$(mktemp)

  for profile in $PROFILES; do
    if ! json=$(aws configure export-credentials --profile "$profile" 2>"$err"); then
      log "cannot resolve credentials for profile '$profile': $(tr '\n' ' ' <"$err" | head -c 300)"
      failed=$((failed + 1))
      first=0 # [default] belongs to the first LISTED profile; don't promote a later one
      continue
    fi

    akid=$(jq -re .AccessKeyId <<<"$json")
    secret=$(jq -re .SecretAccessKey <<<"$json")
    # SessionToken/Expiration are absent for static (non-STS) credentials
    token=$(jq -r '.SessionToken // empty' <<<"$json")
    exp=$(jq -r '.Expiration // empty' <<<"$json")

    if [ "$first" = 1 ]; then
      write_section default "$akid" "$secret" "$token" >>"$tmp"
    fi
    write_section "$profile" "$akid" "$secret" "$token" >>"$tmp"

    if [ -n "$exp" ] && exp_epoch=$(date -d "$exp" +%s 2>/dev/null); then
      if [ -z "$min_exp_epoch" ] || [ "$exp_epoch" -lt "$min_exp_epoch" ]; then
        min_exp_epoch=$exp_epoch
        min_exp=$exp
      fi
    fi

    vended=$((vended + 1))
    first=0
  done
  rm -f "$err"

  if [ "$vended" = 0 ]; then
    rm -f "$tmp"
    log "no profiles could be vended; if the SSO session is missing/expired, run: aws sso login"
    return 1
  fi

  mv "$tmp" "$SHELF/credentials"
  printf '%s\n' "${min_exp:-unknown}" >"$SHELF/expiration"
  log "vended $vended profile(s) (earliest expiry ${min_exp:-unknown})"
  [ "$failed" = 0 ] || log "WARNING: $failed profile(s) failed and are missing from the shelf this round"
}

if [ "${1:-}" = "--once" ]; then
  vend
  exit $?
fi

log "starting; vending profiles [$PROFILES] to $SHELF (refresh <${REFRESH_BEFORE}s remaining, check every ${CHECK_INTERVAL}s)"
while true; do
  if needs_vend; then
    if vend; then status_ok; else status_stalled; fi
  else
    status_ok # heartbeat: credentials on the shelf are still fresh
  fi
  sleep "$CHECK_INTERVAL"
done
