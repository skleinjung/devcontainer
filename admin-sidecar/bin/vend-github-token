#!/usr/bin/env bash
#
# vend-github-token — mint a scoped GitHub App installation token (App JWT signed via AWS KMS)
# and publish it onto the /creds shelf for the agent workspace.
#
# Minting lives in the admin sidecar so token scope is decided HERE — by this configuration and
# by IAM (who may kms:Sign) — never by the consumer: agents find a pre-scoped token at
# $VEND_SHELF_DIR/github/$VEND_GH_TOKEN_NAME ("<exp_epoch> <token>", the format gh-token-get
# reads) and have no way to request anything broader. Escalation means a human vends a broader
# token from this container. CI mints its own tokens (inline JWT→KMS→exchange in publish.yaml).
# Design context: https://github.com/twin-digital/opus/issues/164
#
# One loop per GitHub App installation (one installation == one org). vend-daemon reads
# github-installations.json and launches a loop per entry, setting the per-installation vars
# below. The token lands at /creds/github/<VEND_GH_TOKEN_NAME> — by convention the org name — so
# the shelf filenames double as the consuming side's org→token routing table.
#
# Config (env):
#   VEND_GH_APP_ID            GitHub App id                                    (common, compose)
#   VEND_GH_KMS_KEY_ID        KMS alias/id/arn of the App signing key          (common, compose)
#   VEND_GH_AWS_PROFILE       profile (admin ~/.aws/config) holding kms:Sign   (common, compose)
#   VEND_GH_AWS_REGION        region of the KMS key (default us-east-1)        (common, compose)
#   VEND_GH_INSTALLATION_ID   installation to mint against                     (per-installation)
#   VEND_GH_TOKEN_NAME        shelf filename, conventionally the org           (per-installation)
#   VEND_GH_REPOS             JSON array narrowing repos (empty = all installed)  (per-installation)
#   VEND_GH_PERMS             JSON object narrowing permissions (empty = full grant) (per-installation)
#
# Runs as a loop under vend-daemon (the sidecar's main process). Tokens last ~1h; the loop
# re-mints when less than $VEND_REFRESH_BEFORE seconds remain. With no resolvable AWS
# credentials it logs and keeps waiting (run `aws sso login` here).
# `vend-github-token --once` vends a single time and exits nonzero on failure.
set -euo pipefail

APP_ID="${VEND_GH_APP_ID:?set VEND_GH_APP_ID}"
INSTALLATION_ID="${VEND_GH_INSTALLATION_ID:?set VEND_GH_INSTALLATION_ID}"
KMS_KEY_ID="${VEND_GH_KMS_KEY_ID:?set VEND_GH_KMS_KEY_ID}"
AWS_PROFILE_OPT=()
[ -z "${VEND_GH_AWS_PROFILE:-}" ] || AWS_PROFILE_OPT=(--profile "$VEND_GH_AWS_PROFILE")
AWS_REGION_OPT=(--region "${VEND_GH_AWS_REGION:-us-east-1}")
REPOS_JSON="${VEND_GH_REPOS:-}"
PERMS_JSON="${VEND_GH_PERMS:-}"
TOKEN_NAME="${VEND_GH_TOKEN_NAME:?set VEND_GH_TOKEN_NAME (shelf filename, conventionally the org)}"
SHELF="${VEND_SHELF_DIR:-/creds}/github"
REFRESH_BEFORE="${VEND_REFRESH_BEFORE:-600}" # re-mint when less than 10 min remain
CHECK_INTERVAL="${VEND_CHECK_INTERVAL:-60}"

# Prefix with the org/token name so the five parallel loops are distinguishable in the log.
log() { printf '%s vend-github-token[%s]: %s\n' "$(date -Is)" "$TOKEN_NAME" "$*"; }

# Health stamp for consumers (shell prompts, gh-token-get breadcrumbs, future healthchecks):
# one line, "ok ..." or "stalled ...", rewritten every cycle so mtime doubles as a heartbeat.
# Per-installation (github-<name>) so parallel loops don't clobber a shared file.
STATUS_FILE="${VEND_SHELF_DIR:-/creds}/status/github-${TOKEN_NAME}"
stalled_since=""
status_write() {
  local tmp
  mkdir -p "${STATUS_FILE%/*}"
  tmp=$(mktemp "${STATUS_FILE%/*}/.github-${TOKEN_NAME}.XXXXXX")
  printf '%s\n' "$1" >"$tmp"
  mv "$tmp" "$STATUS_FILE"
}
status_ok() {
  local exp
  exp=$(cut -d' ' -f1 "$SHELF/$TOKEN_NAME" 2>/dev/null || true)
  stalled_since=""
  status_write "ok expires=$(date -d "@${exp:-0}" -Is 2>/dev/null || echo unknown)"
}
status_stalled() {
  [ -n "$stalled_since" ] || stalled_since=$(date -Is)
  status_write "stalled since=$stalled_since fix=\"docker exec -it admin-sidecar aws-refresh-sso <profile>\" logs=\"docker logs admin-sidecar\""
}

b64url() { openssl base64 -A | tr '+/' '-_' | tr -d '='; }

needs_vend() {
  local line exp
  line=$(cat "$SHELF/$TOKEN_NAME" 2>/dev/null) || return 0
  exp="${line%% *}"
  [ "$exp" -gt 0 ] 2>/dev/null || return 0
  [ $((exp - $(date +%s))) -lt "$REFRESH_BEFORE" ]
}

vend() {
  local now header payload signing_input msg sig_b64 sig jwt body resp code json
  local token exp_iso exp_epoch tmp

  # ── build JWT (RS256), sign header.payload with KMS ──────────────────────
  now=$(date +%s)
  header='{"alg":"RS256","typ":"JWT"}'
  payload=$(printf '{"iat":%d,"exp":%d,"iss":"%s"}' "$((now - 60))" "$((now + 480))" "$APP_ID")
  signing_input="$(printf '%s' "$header" | b64url).$(printf '%s' "$payload" | b64url)"

  msg=$(mktemp)
  printf '%s' "$signing_input" >"$msg"
  # RS256 == RSASSA_PKCS1_V1_5_SHA_256; MessageType RAW => KMS hashes the input itself.
  if ! sig_b64=$(aws "${AWS_PROFILE_OPT[@]}" "${AWS_REGION_OPT[@]}" kms sign \
      --key-id "$KMS_KEY_ID" --message "fileb://$msg" --message-type RAW \
      --signing-algorithm RSASSA_PKCS1_V1_5_SHA_256 --query Signature --output text 2>"$msg.err"); then
    log "kms sign failed: $(tr '\n' ' ' <"$msg.err" | head -c 300)"
    log "if the SSO session is missing/expired, run: aws sso login${VEND_GH_AWS_PROFILE:+ --profile $VEND_GH_AWS_PROFILE}"
    rm -f "$msg" "$msg.err"
    return 1
  fi
  rm -f "$msg.err"
  sig=$(printf '%s' "$sig_b64" | openssl base64 -d -A | b64url)
  jwt="${signing_input}.${sig}"
  rm -f "$msg"

  # ── exchange JWT -> scoped installation token ────────────────────────────
  # Include only the fields that are set; omitted fields grant the App's full scope there.
  body=$(jq -nc --argjson repos "${REPOS_JSON:-null}" --argjson perms "${PERMS_JSON:-null}" \
    '{repositories: $repos, permissions: $perms} | with_entries(select(.value != null))')

  resp=$(curl -sS -X POST \
    -H "Authorization: Bearer $jwt" \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2022-11-28" \
    "https://api.github.com/app/installations/${INSTALLATION_ID}/access_tokens" \
    -d "$body" -w $'\n%{http_code}') || { log "request to GitHub failed"; return 1; }

  code=${resp##*$'\n'}
  json=${resp%$'\n'*}
  # Only surface .message — never the whole body (a misparsed 201 body would hold the token).
  if [ "$code" != 201 ]; then
    hint=""
    [ "$code" = 404 ] && hint=" (installation ${INSTALLATION_ID} is not a valid installation of App ${APP_ID} — check the id, or that this App is installed on org '${TOKEN_NAME}')"
    log "GitHub $code: $(printf '%s' "$json" | jq -r '.message // "unknown error"' 2>/dev/null)${hint}"
    return 1
  fi
  token=$(printf '%s' "$json" | jq -r '.token // empty')
  [ -n "$token" ] || { log "no token in response"; return 1; }
  exp_iso=$(printf '%s' "$json" | jq -r '.expires_at')
  exp_epoch=$(date -d "$exp_iso" +%s 2>/dev/null || echo "$((now + 3600))")

  umask 077
  mkdir -p "$SHELF"
  tmp=$(mktemp "$SHELF/.${TOKEN_NAME}.XXXXXX")
  printf '%s %s\n' "$exp_epoch" "$token" >"$tmp"
  mv "$tmp" "$SHELF/$TOKEN_NAME"
  log "vended '$TOKEN_NAME' token repos=${REPOS_JSON:-<all-installed>} perms=${PERMS_JSON:-<full-app-grant>} (expires $exp_iso)"
}

if [ "${1:-}" = "--once" ]; then
  vend
  exit $?
fi

log "starting; vending token '$TOKEN_NAME' to $SHELF (refresh <${REFRESH_BEFORE}s remaining, check every ${CHECK_INTERVAL}s)"
while true; do
  if needs_vend; then
    if vend; then status_ok; else status_stalled; fi
  else
    status_ok # heartbeat: the token on the shelf is still fresh
  fi
  sleep "$CHECK_INTERVAL"
done
