#!/usr/bin/env bash
# vend-daemon — the admin sidecar's main process: supervises the credential vend loops.
# One AWS loop, plus one GitHub loop per installation listed in github-installations.json
# (one installation == one org; its token lands at /creds/github/<name>). Each loop is
# self-contained (own cadence, own shelf files); if any dies, exit so the container's restart
# policy brings the whole set back up.
set -euo pipefail

INSTALLATIONS="${GH_INSTALLATIONS_FILE:-/etc/admin-sidecar/github-installations.json}"

vend-aws-creds &

if [ -f "$INSTALLATIONS" ]; then
  count=$(jq 'length' "$INSTALLATIONS")
  for i in $(seq 0 $((count - 1))); do
    entry=$(jq -c ".[$i]" "$INSTALLATIONS")
    # name defaults to org; repos/perms optional (empty => App's full grant for that field)
    export VEND_GH_INSTALLATION_ID="$(jq -r '.installation_id' <<<"$entry")"
    export VEND_GH_TOKEN_NAME="$(jq -r '.name // .org' <<<"$entry")"
    export VEND_GH_REPOS="$(jq -rc '.repos // empty' <<<"$entry")"
    export VEND_GH_PERMS="$(jq -rc '.perms // empty' <<<"$entry")"
    vend-github-token &
  done
else
  echo "vend-daemon: $INSTALLATIONS not found; no GitHub tokens will be vended" >&2
fi

wait -n
echo "vend-daemon: a vend loop exited; restarting container" >&2
exit 1
